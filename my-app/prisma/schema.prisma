generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

model Booking {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String
  packageSlug String
  travelDate  DateTime
  guests      Int
  totalAmount Float
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
}