model Booking {
  id            String    @id @default(cuid())
  userId        String
  email         String
  bookingRef    String    @unique
  packageSlug   String
  packageName   String?
  packageImage  String?
  location      String?
  duration      String?
  travelDate    DateTime
  guests        Int
  totalAmount   Float
  status        String    @default("confirmed")
  bookingType   String    @default("package")  // ← add this
  serviceDetails String?                        // ← add this
  createdAt     DateTime  @default(now())
  cancelledAt   DateTime?
}