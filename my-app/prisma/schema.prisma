generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Booking {
  id            String    @id @default(cuid())
  userId        String
  email         String
  bookingRef    String    @unique
  packageSlug   String
  packageName   String?
  packageImage  String?
  location      String?
  duration      String?
  travelDate    DateTime
  guests        Int
  totalAmount   Float
  status        String    @default("confirmed")
  createdAt     DateTime  @default(now())
  cancelledAt   DateTime?
}